# ─── NexusOps AI — Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ── LLM API Keys (configure at least one for AI synthesis) ──────────────────────
# OpenAI (GPT-4o-mini recommended for cost efficiency, GPT-4o for best quality)
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini (gemini-1.5-flash or gemini-1.5-pro)
GOOGLE_API_KEY=your-google-api-key-here

# Anthropic Claude (claude-3-haiku-20240307 for speed, claude-3-5-sonnet for quality)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Optional: Pinecone (if replacing ChromaDB with hosted vector store) ──────────
# PINECONE_API_KEY=your-pinecone-api-key-here
# PINECONE_ENVIRONMENT=us-east-1-aws
# PINECONE_INDEX_NAME=nexusops-ai

# ── Optional: Tesseract Path (if using pytesseract fallback) ────────────────────
# TESSERACT_CMD=/usr/local/bin/tesseract  # macOS with Homebrew
# TESSERACT_CMD=/usr/bin/tesseract        # Linux

# ── App Settings ─────────────────────────────────────────────────────────────────
# NEXUSOPS_LOG_LEVEL=INFO
# NEXUSOPS_CHROMA_DIR=./data/chroma_db
